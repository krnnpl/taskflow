# Dependencies - never commit these
node_modules/
*/node_modules/
**/node_modules/

# Environment files - NEVER push to GitHub
.env
.env.local
.env.production
backend/.env
frontend/.env
*.env

# Uploads - user files stored locally
backend/uploads/*
!backend/uploads/.gitkeep

# Frontend build output
frontend/build/
frontend/.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Railway
.railway/
